---
import SiteLayout from '../layouts/SiteLayout.astro';
import TopNav from '../components/site/TopNav.astro';
import HeroSection from '../components/hero/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import Footer from '../components/site/Footer.astro';
import { site } from '../data/site';
import { skills } from '../data/skills';
import { projects } from '../data/projects';
import { contactLinks } from '../data/contact';

const navItems = [
  { id: '#', label: 'Intro' },
  { id: '#about', label: 'About' },
  { id: '#skills', label: 'Skills' },
  { id: '#projects', label: 'Projects' },
  { id: '#contact', label: 'Contact' },
];
---

<SiteLayout title={site.title} description={site.description}>
  <TopNav items={navItems} title={site.title} />
  <main>
    <HeroSection eyebrow={site.hero.eyebrow} heading={site.hero.heading} />
    <AboutSection title={site.about.title} paragraphs={site.about.paragraphs} />
    <SkillsSection skills={skills} />
    <ProjectsSection projects={projects} />
    <ContactSection
      title={site.contact.title}
      intro={site.contact.intro}
      links={contactLinks}
    />
  </main>
  <Footer />

  <script is:inline>
    const syncNavOffset = () => {
      const nav = document.querySelector('[data-nav-root]');
      if (!(nav instanceof HTMLElement)) return 65;

      const navHeight = nav.offsetHeight;
      document.documentElement.style.setProperty(
        '--nav-offset',
        `${navHeight}px`,
      );
      return navHeight;
    };

    const scrollToHash = (hash) => {
      const target = document.querySelector(hash);
      if (!(target instanceof HTMLElement)) return;

      const top = target.offsetTop;
      window.scrollTo({ top, behavior: 'smooth' });
    };

    const setActiveNavLink = (hash) => {
      document.querySelectorAll('[data-nav-link]').forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;

        const active = link.getAttribute('href') === hash;
        link.toggleAttribute('data-active', active);

        if (active) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const initActiveNavTracking = () => {
      const nav = document.querySelector('[data-nav-root]');
      if (!(nav instanceof HTMLElement)) return;

      const sections = ['#about', '#skills', '#projects', '#contact']
        .map((hash) => {
          const element = document.querySelector(hash);
          return element instanceof HTMLElement ? { hash, element } : null;
        })
        .filter(Boolean);

      let frame = 0;

      const updateActiveNav = () => {
        const scrollMarker = window.scrollY + nav.offsetHeight + 24;
        let currentHash = '#';

        sections.forEach((section) => {
          if (section.element.offsetTop <= scrollMarker) {
            currentHash = section.hash;
          }
        });

        setActiveNavLink(currentHash);
      };

      const scheduleUpdate = () => {
        if (frame) return;

        frame = window.requestAnimationFrame(() => {
          frame = 0;
          updateActiveNav();
        });
      };

      updateActiveNav();
      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate);
      window.addEventListener(
        'pagehide',
        () => {
          if (frame) {
            window.cancelAnimationFrame(frame);
          }
        },
        { once: true },
      );
    };

    document.addEventListener('click', (event) => {
      const link =
        event.target instanceof Element
          ? event.target.closest('a[href^="#"]')
          : null;
      if (!(link instanceof HTMLAnchorElement)) return;

      const hash = link.getAttribute('href');
      if (!hash || hash === '#') return;

      event.preventDefault();
      history.replaceState(null, '', hash);
      setActiveNavLink(hash);
      scrollToHash(hash);
    });

    window.addEventListener('resize', () => {
      syncNavOffset();
    });

    window.addEventListener('load', () => {
      syncNavOffset();
      initActiveNavTracking();
      if (window.location.hash) {
        requestAnimationFrame(() => scrollToHash(window.location.hash));
      }
    });
  </script>
</SiteLayout>
