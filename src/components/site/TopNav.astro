---
interface NavItem {
  id: string;
  label: string;
}

interface Props {
  items: NavItem[];
  title: string;
}

const { items, title } = Astro.props;
---

<nav class="top-nav" aria-label="Primary" data-nav-root>
  <div class="section-shell nav-shell">
    <a class="brand" href="#">{title}</a>
    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-menu"
      data-menu-toggle
    >
      <span>Menu</span>
      <span class="menu-icon" aria-hidden="true">+</span>
    </button>

    <div
      class="menu-panel"
      id="site-menu"
      data-menu-panel
      aria-hidden="true"
      data-open="false"
    >
      <ul class="menu-list">
        {
          items.map((item) => (
            <li>
              <a href={item.id} data-menu-link data-nav-link>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>

<script is:inline>
  const toggle = document.querySelector('[data-menu-toggle]');
  const panel = document.querySelector('[data-menu-panel]');
  const links = document.querySelectorAll('[data-menu-link]');
  const navRoot = document.querySelector('[data-nav-root]');

  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    const setOpen = (open) => {
      if (!open && panel.contains(document.activeElement)) {
        toggle.focus();
      }

      toggle.setAttribute('aria-expanded', String(open));
      panel.dataset.open = String(open);
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('menu-open', open);
    };

    setOpen(false);

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') !== 'true';
      setOpen(open);
    });

    links.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 960) {
        setOpen(false);
      }
    });
  }

  if (navRoot instanceof HTMLElement) {
    const setShrunk = () => {
      navRoot.dataset.shrunk = String(window.scrollY > 100);
    };

    setShrunk();
    window.addEventListener('scroll', setShrunk, { passive: true });
  }
</script>

<style>
  .top-nav {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 20;
    backdrop-filter: blur(3px);
    border-bottom: 1px solid rgb(255 255 255 / 10%);
  }

  .top-nav[data-shrunk='true'] {
    background: rgb(2 4 7 / 72%);
    backdrop-filter: blur(16px);
  }

  .nav-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    min-height: 4rem;
    width: min(calc(100% - 1.5rem), 72rem);
    position: relative;
  }

  .brand {
    font-family: Cabin, 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 2.45rem;
    padding: 0.5rem 0.85rem;
    color: var(--color-text);
    border: 1px solid rgb(255 255 255 / 16%);
    border-radius: 999px;
    background: rgb(12 16 24 / 88%);
    box-shadow: 0 10px 24px rgb(0 0 0 / 22%);
  }

  .menu-toggle:focus-visible,
  .menu-toggle:hover {
    border-color: rgb(66 220 163 / 60%);
    background: rgb(66 220 163 / 12%);
    outline: none;
  }

  .menu-icon {
    font-size: 1.1rem;
    line-height: 1;
    transition: transform 220ms ease;
  }

  .menu-toggle[aria-expanded='true'] .menu-icon {
    transform: rotate(45deg);
  }

  .menu-panel {
    position: absolute;
    top: calc(100% - 0.15rem);
    right: 0;
    z-index: 30;
    width: min(14.5rem, calc(100vw - 1.5rem));
    margin-top: 0;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(255 255 255 / 10%);
    border-radius: 1rem;
    background: rgb(7 11 18 / 96%);
    box-shadow: 0 20px 48px rgb(0 0 0 / 40%);
    max-height: 0;
    opacity: 0;
    transform: translateY(-0.5rem) scale(0.98);
    transform-origin: top right;
    pointer-events: none;
    overflow: hidden;
    transition:
      max-height 220ms ease,
      margin-top 220ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .menu-panel[data-open='true'] {
    margin-top: 0.5rem;
    max-height: 18rem;
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    justify-items: stretch;
    gap: 0.15rem;
  }

  .menu-list a {
    display: flex;
    justify-content: flex-end;
    width: 100%;
    padding: 0.8rem 0.2rem;
    font-family: Cabin, 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid rgb(255 255 255 / 8%);
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .menu-list a:hover,
  .menu-list a[data-active],
  .menu-list a[aria-current='page'],
  .menu-list a:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .menu-list li:last-child a {
    border-bottom: 0;
  }

  @media (--desktop-and-up) {
    .top-nav {
      border-bottom-color: transparent;
      background: transparent;
      backdrop-filter: none;
      transition:
        background-color 260ms ease,
        border-bottom-color 260ms ease,
        backdrop-filter 260ms ease;
    }

    .nav-shell {
      grid-template-columns: auto 1fr;
      width: min(calc(100% - 3rem), 72rem);
      min-height: 5.6rem;
      transition: min-height 260ms ease;
    }

    .top-nav[data-shrunk='true'] {
      border-bottom-color: rgb(255 255 255 / 10%);
      background: rgb(8 12 18 / 62%);
      backdrop-filter: blur(16px);
    }

    .top-nav[data-shrunk='true'] .nav-shell {
      min-height: 4rem;
    }

    .menu-toggle {
      display: none;
    }

    .menu-panel {
      position: static;
      grid-column: auto;
      width: auto;
      max-height: none;
      margin-top: 0;
      overflow: visible;
      opacity: 1;
      padding: 0;
      transform: none;
      pointer-events: auto;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      backdrop-filter: none;
      justify-self: end;
    }

    .menu-list {
      grid-auto-flow: column;
      gap: 1.35rem;
      align-items: center;
    }

    .menu-list a {
      position: relative;
      isolation: isolate;
      padding: 0.38rem 0.72rem;
      background: transparent;
      border-bottom: 0;
    }

    .brand {
      position: relative;
      isolation: isolate;
      display: inline-flex;
      align-items: center;
      min-height: 2.45rem;
      padding: 0.38rem 0.72rem;
      color: var(--color-text);
    }

    .top-nav:not([data-shrunk='true']) .menu-list a::before,
    .top-nav:not([data-shrunk='true']) .brand::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: -1;
      border-radius: 999px;
      background: var(--color-panel);
      box-shadow: var(--shadow-elevated);
      backdrop-filter: blur(3px);
      pointer-events: none;
    }

    .menu-list a:hover,
    .menu-list a[data-active],
    .menu-list a[aria-current='page'],
    .menu-list a:focus-visible {
      background: transparent;
    }

    .top-nav[data-shrunk='true'] .menu-list a,
    .top-nav[data-shrunk='true'] .brand {
      box-shadow: none;
    }
  }
</style>
