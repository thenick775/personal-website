---
interface NavItem {
  id: string;
  label: string;
}

interface Props {
  items: NavItem[];
  title: string;
}

const { items, title } = Astro.props;
---

<nav class="top-nav" aria-label="Primary" data-nav-root>
  <div class="section-shell nav-shell">
    <a class="brand" href="#page-top">{title}</a>
    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-menu"
      data-menu-toggle
    >
      <span>Menu</span>
      <span class="menu-icon" aria-hidden="true">+</span>
    </button>

    <div class="menu-panel" id="site-menu" data-menu-panel aria-hidden="true" data-open="false">
      <ul class="menu-list">
        {items.map((item) => (
          <li>
            <a href={`#${item.id}`} data-menu-link>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script is:inline>
  const toggle = document.querySelector('[data-menu-toggle]');
  const panel = document.querySelector('[data-menu-panel]');
  const links = document.querySelectorAll('[data-menu-link]');

  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    const setOpen = (open) => {
      toggle.setAttribute('aria-expanded', String(open));
      panel.dataset.open = String(open);
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('menu-open', open);
    };

    setOpen(false);

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') !== 'true';
      setOpen(open);
    });

    links.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 960) {
        setOpen(false);
      }
    });
  }
</script>

<style>
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(16px);
    background: rgba(2, 4, 7, 0.72);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    min-height: 4.75rem;
    width: min(calc(100% - 1.5rem), 72rem);
    position: relative;
  }

  .brand {
    font-family: 'Cabin', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 2.45rem;
    padding: 0.5rem 0.85rem;
    color: var(--color-text);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: rgba(12, 16, 24, 0.88);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
  }

  .menu-toggle:focus-visible,
  .menu-toggle:hover {
    border-color: rgba(66, 220, 163, 0.6);
    background: rgba(66, 220, 163, 0.12);
    outline: none;
  }

  .menu-icon {
    font-size: 1.1rem;
    line-height: 1;
    transition: transform 220ms ease;
  }

  .menu-toggle[aria-expanded='true'] .menu-icon {
    transform: rotate(45deg);
  }

  .menu-panel {
    position: absolute;
    top: calc(100% - 0.15rem);
    right: 0;
    z-index: 30;
    width: min(14.5rem, calc(100vw - 1.5rem));
    margin-top: 0;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    background: rgba(7, 11, 18, 0.96);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.4);
    max-height: 0;
    opacity: 0;
    transform: translateY(-0.5rem) scale(0.98);
    transform-origin: top right;
    pointer-events: none;
    overflow: hidden;
    transition:
      max-height 220ms ease,
      margin-top 220ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .menu-panel[data-open='true'] {
    margin-top: 0.5rem;
    max-height: 18rem;
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    justify-items: stretch;
    gap: 0.15rem;
  }

  .menu-list a {
    display: flex;
    justify-content: flex-end;
    width: 100%;
    padding: 0.8rem 0.2rem;
    font-family: 'Cabin', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .menu-list li:last-child a {
    border-bottom: 0;
  }

  .menu-list a:hover,
  .menu-list a:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  @media (min-width: 960px) {
    .nav-shell {
      grid-template-columns: auto 1fr;
      width: min(calc(100% - 3rem), 72rem);
    }

    .menu-toggle {
      display: none;
    }

    .menu-panel {
      position: static;
      grid-column: auto;
      width: auto;
      margin-top: 0;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      justify-self: end;
    }

    .menu-list {
      grid-auto-flow: column;
      gap: 1.35rem;
      align-items: center;
    }

    .menu-panel {
      max-height: none;
      overflow: visible;
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }

    .menu-list a {
      padding: 0;
    }
  }
</style>
