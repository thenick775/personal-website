---
interface Props {
  href: string;
  label?: string;
}

const { href, label = "Scroll to next section" } = Astro.props;
---

<a class="section-next-link" href={href} aria-label={label}>
  <span class="section-next-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" focusable="false">
      <path d="m6 8 6 6 6-6"></path>
      <path d="m6 13 6 6 6-6"></path>
    </svg>
  </span>
</a>

<style>
  .section-next-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 999px;
    background: rgb(8 12 18 / 42%);
    box-shadow: 0 14px 30px rgb(0 0 0 / 22%);
    backdrop-filter: blur(3px);
    color: rgb(245 247 251 / 84%);
    transition:
      transform 180ms ease,
      color 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .section-next-link:hover,
  .section-next-link:focus-visible {
    transform: translateY(-1px);
    color: var(--color-accent);
    border-color: rgb(66 220 163 / 50%);
    background: rgb(66 220 163 / 8%);
    outline: none;
  }

  .section-next-icon {
    display: inline-flex;
    width: 1.2rem;
    height: 1.2rem;
  }

  .section-next-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentcolor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
