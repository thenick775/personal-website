---
import { Image } from "astro:assets";
import vLogo from "../../assets/v.png";
---

<footer class="site-footer">
  <div class="section-shell footer-shell">
    <a class="footer-mark" href="#intro" aria-label="Back to top">
      <Image
        class="logo"
        src={vLogo}
        alt="Logo"
        width={38}
        height={35}
        quality="high"
        format="png"
        loading="lazy"
      />
    </a>
    <p>Copyright © Nicholas VanCise</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2.5rem 0 1rem;
  }

  .footer-shell {
    display: grid;
    justify-items: center;
    gap: 1rem;
    color: rgb(255 255 255 / 72%);
  }

  .footer-mark {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 18%);
    font-family: Cabin, "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-weight: 700;
    color: var(--color-text);
  }

  .logo {
    margin-top: 9px;
  }

  p {
    margin: 0;
    font-size: 0.9rem;
  }
</style>
