<canvas class="matrix-canvas" data-matrix-canvas aria-hidden="true"></canvas>

<script is:inline>
  const canvas = document.querySelector("[data-matrix-canvas]");

  if (canvas instanceof HTMLCanvasElement) {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const context = canvas.getContext("2d");

    if (context && !reduceMotion) {
      const glyphs =
        "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ123456789诶比西迪伊艾弗吉艾尺艾杰开艾勒艾马艾娜哦屁吉吾艾儿艾一，@#$%^&*()*&^%+-/~{[|`]}".split(
          "",
        );
      const fontSize = 12;
      let columns = 0;
      let rows = 0;
      let drops = [];
      let rafId = 0;
      let lastFrame = 0;
      let visible = true;
      let width = 0;
      let height = 0;
      let dpr = window.devicePixelRatio || 1;
      let widthPollId = 0;

      const setup = (force = false) => {
        const nextDpr = window.devicePixelRatio || 1;
        const nextWidth = window.innerWidth;
        const nextHeight = window.innerHeight;

        if (!nextWidth || !nextHeight) return;

        const widthChanged = nextWidth !== width;
        const dprChanged = nextDpr !== dpr;

        // ignore iOS liquid-glass height churn during scroll only
        // rebuild on actual width changes or DPR/orientation changes.
        if (!force && width && !widthChanged && !dprChanged) return;

        const previousColumns = columns;
        const previousRows = rows;
        const previousDrops = drops;

        width = nextWidth;
        height = nextHeight;
        dpr = nextDpr;

        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        context.setTransform(dpr, 0, 0, dpr, 0, 0);
        context.clearRect(0, 0, width, height);

        const nextColumns = Math.max(1, Math.ceil(width / fontSize));
        const nextRows = Math.max(1, Math.floor(height / fontSize));

        drops = Array.from({ length: nextColumns }, (_, index) => {
          if (!previousColumns || !previousRows) {
            return Math.floor(Math.random() * nextRows + 1);
          }

          const mappedIndex = Math.min(
            previousColumns - 1,
            Math.floor((index / nextColumns) * previousColumns),
          );
          const normalizedDrop = previousDrops[mappedIndex] / previousRows;

          return Math.max(
            0,
            Math.min(nextRows + 1, Math.round(normalizedDrop * nextRows)),
          );
        });

        columns = nextColumns;
        rows = nextRows;
      };

      const draw = (timestamp) => {
        if (!visible) {
          rafId = window.requestAnimationFrame(draw);
          return;
        }

        if (timestamp - lastFrame >= 75) {
          lastFrame = timestamp;
          context.fillStyle = "rgba(0, 0, 0, 0.04)";
          context.fillRect(0, 0, width, height);

          context.fillStyle = `hsl(${Math.random() * 360}, 90%, 50%)`;
          context.font = `${fontSize}px Arial`;

          for (let i = 0; i < columns; i += 1) {
            const glyph = glyphs[Math.floor(Math.random() * glyphs.length)];
            context.fillText(glyph, i * fontSize, drops[i] * fontSize);

            if (drops[i] * fontSize > height && Math.random() > 0.977) {
              drops[i] = 0;
            }

            drops[i] += 1;
          }
        }

        rafId = window.requestAnimationFrame(draw);
      };

      const observer = new IntersectionObserver((entries) => {
        visible = Boolean(entries[0]?.isIntersecting);
      });

      setup(true);
      observer.observe(canvas);
      rafId = window.requestAnimationFrame(draw);

      widthPollId = window.setInterval(() => {
        if (window.innerWidth !== width) {
          setup(true);
        }
      }, 1500);

      window.addEventListener(
        "pagehide",
        () => {
          observer.disconnect();
          window.clearInterval(widthPollId);
          window.cancelAnimationFrame(rafId);
        },
        { once: true },
      );
    }
  }
</script>

<style>
  .matrix-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>
