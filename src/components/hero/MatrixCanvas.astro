<canvas class="matrix-canvas" data-matrix-canvas aria-hidden="true"></canvas>

<script is:inline>
  const canvas = document.querySelector('[data-matrix-canvas]');

  if (canvas instanceof HTMLCanvasElement) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const context = canvas.getContext('2d');

    if (context && !reduceMotion) {
      const glyphs = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ123456789诶比西迪伊艾弗吉艾尺艾杰开艾勒艾马艾娜哦屁吉吾艾儿艾一，@#$%^&*()*&^%+-/~{[|`]}'.split('');
      const fontSize = 12;
      let columns = 0;
      let rows = 0;
      let drops = [];
      let rafId = 0;
      let lastFrame = 0;
      let visible = true;

      const setup = () => {
        const dpr = window.devicePixelRatio || 1;
        const width = window.innerWidth;
        const height = window.innerHeight;

        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        context.setTransform(dpr, 0, 0, dpr, 0, 0);

        columns = Math.max(1, Math.floor(width / fontSize));
        rows = Math.max(1, Math.floor(height / fontSize));
        drops = Array.from({ length: columns }, () => Math.floor(Math.random() * rows + 1));
      };

      const draw = (timestamp) => {
        if (!visible) {
          rafId = window.requestAnimationFrame(draw);
          return;
        }

        if (timestamp - lastFrame >= 75) {
          lastFrame = timestamp;
          context.fillStyle = 'rgba(0, 0, 0, 0.06)';
          context.fillRect(0, 0, window.innerWidth, window.innerHeight);

          context.fillStyle = `hsl(${Math.random() * 360}, 90%, 50%)`;
          context.font = `${fontSize}px Arial`;

          for (let i = 0; i < columns; i += 1) {
            const glyph = glyphs[Math.floor(Math.random() * glyphs.length)];
            context.fillText(glyph, i * fontSize, drops[i] * fontSize);

            if (drops[i] * fontSize > window.innerHeight && Math.random() > 0.977) {
              drops[i] = 0;
            }

            drops[i] += 1;
          }
        }

        rafId = window.requestAnimationFrame(draw);
      };

      const observer = new IntersectionObserver((entries) => {
        visible = Boolean(entries[0]?.isIntersecting);
      });

      setup();
      observer.observe(canvas);
      rafId = window.requestAnimationFrame(draw);

      window.addEventListener('resize', setup);
      window.addEventListener('pagehide', () => window.cancelAnimationFrame(rafId), { once: true });
    }
  }
</script>

<style>
  .matrix-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.9;
  }
</style>
