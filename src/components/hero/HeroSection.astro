---
import type { site } from '../../data/site';
import MatrixCanvas from './MatrixCanvas.astro';

interface Props {
  eyebrow: string;
  heading: string;
}

const { eyebrow, heading } = Astro.props;
---

<header id="page-top" class="hero-block">
  <MatrixCanvas />
  <div class="hero-overlay"></div>
  <div class="section-shell hero-shell">
    <div class="hero-copy surface-panel">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="intro-copy">
        Building distributed systems, backend tooling, and odd little side
        projects that turn into much larger ones.
      </p>
      <a class="button-pill button-primary hero-cta" href="#about">
        Explore the site
      </a>
    </div>
  </div>
</header>

<style>
  .hero-block {
    position: relative;
    isolation: isolate;
    min-height: calc(100dvh - var(--nav-offset));;
    overflow: clip;
    display: grid;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(2, 3, 5, 0.18), rgba(2, 3, 5, 0.6)),
      radial-gradient(circle at center, transparent 0%, rgba(2, 3, 5, 0.65) 72%);
  }

  .hero-shell {
    display: flex;
    justify-content: center;
    padding-top: 5.5rem;
    padding-bottom: 3rem;
  }

  .hero-copy {
    width: min(100%, 38rem);
    padding: clamp(1rem, 3vw, 1.75rem);
    text-align: center;
  }

  h1 {
    margin: 0;
    font-family: 'Cabin', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .intro-copy {
    margin: 1.35rem 0 0;
    max-width: 31rem;
    margin-left: auto;
    margin-right: auto;
    font-size: clamp(1rem, 1.45vw, 1.1rem);
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .hero-cta {
    margin-top: 1.65rem;
  }

  @media (min-width: 960px) {
    .hero-shell {
      padding-top: 6.5rem;
      padding-bottom: 4rem;
    }

    .hero-copy {
      width: min(100%, 44rem);
      padding: 1.5rem 1.75rem;
    }
  }
</style>
