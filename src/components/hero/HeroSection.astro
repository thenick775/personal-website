---
import MatrixCanvas from './MatrixCanvas.astro';

interface Props {
  eyebrow: string;
  heading: string;
}

const { eyebrow, heading } = Astro.props;
---

<header class="hero-block">
  <MatrixCanvas />
  <div class="hero-overlay"></div>
  <div class="section-shell hero-shell">
    <div class="hero-copy hero-surface-panel">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="intro-copy">
        Building distributed systems, backend tooling, and odd little side
        projects that turn into much larger ones.
      </p>
      <a class="button-pill button-primary hero-cta" href="#about">
        Explore my site
      </a>
    </div>
  </div>
</header>

<style>
  .hero-block {
    position: relative;
    isolation: isolate;
    min-height: 100lvh;
    overflow: visible;
    display: grid;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(2, 3, 5, 0.18), rgba(2, 3, 5, 0.6)),
      radial-gradient(circle at center, transparent 0%, rgba(2, 3, 5, 0.65) 72%);
  }

  .hero-surface-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-elevated);
    backdrop-filter: blur(3px);
  }

  .hero-shell {
    display: flex;
    justify-content: center;
    padding-bottom: 8rem;
  }

  .hero-copy {
    width: min(100%, 29rem);
    padding: 0.9rem 0;
    text-align: center;
  }

  h1 {
    margin: 0;
    font-family: 'Cabin', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(1.35rem, 4vw, 1.8rem);
    line-height: 0.96;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .intro-copy {
    margin: 1rem 0 0;
    max-width: 31rem;
    margin-left: auto;
    margin-right: auto;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .hero-cta {
    margin-top: 1.25rem;
  }

  @media (--tablet-and-up) {
    .hero-copy {
      width: min(100%, 38rem);
      padding: clamp(1rem, 3vw, 1.75rem);
    }

    h1 {
      font-size: clamp(2rem, 3vw, 2.3rem);
      line-height: 1.02;
    }

    .intro-copy {
      margin-top: 1.35rem;
      font-size: clamp(1rem, 1.45vw, 1.1rem);
      line-height: 1.7;
    }

    .hero-cta {
      margin-top: 1.65rem;
    }

    .hero-shell {
      padding-bottom: 12rem;
    }
  }

  @media (--desktop-and-up) {
    .hero-copy {
      width: min(100%, 44rem);
      padding: 1.5rem 1.75rem;
    }
  }
</style>
