<dialog class="project-dialog surface-panel" data-project-dialog>
  <form method="dialog" class="dialog-shell">
    <div class="dialog-header">
      <p class="eyebrow">Project</p>
      <button
        class="dialog-close"
        type="submit"
        aria-label="Close project detail dialog"
      >
        ×
      </button>
    </div>
    <h3 class="dialog-title" data-project-dialog-title>Project detail</h3>
    <p class="dialog-copy" data-project-dialog-copy></p>
    <div class="dialog-actions" data-project-dialog-actions hidden>
      <a
        class="button-pill button-primary"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        data-project-dialog-link
      >
        View project
      </a>
    </div>
  </form>
</dialog>

<script is:inline>
  const dialog = document.querySelector("[data-project-dialog]");
  const title = document.querySelector("[data-project-dialog-title]");
  const copy = document.querySelector("[data-project-dialog-copy]");
  const actions = document.querySelector("[data-project-dialog-actions]");
  const link = document.querySelector("[data-project-dialog-link]");
  if (
    dialog instanceof HTMLDialogElement &&
    title instanceof HTMLElement &&
    copy instanceof HTMLElement &&
    actions instanceof HTMLElement &&
    link instanceof HTMLAnchorElement
  ) {
    const projectsRoot = document.querySelector("#projects");
    const triggers =
      projectsRoot?.querySelectorAll("[data-project-detail]") ?? [];

    const setScrollLock = (locked) => {
      document.body.classList.toggle("dialog-open", locked);
    };

    triggers.forEach((trigger) => {
      if (!(trigger instanceof HTMLElement)) return;

      trigger.addEventListener("click", () => {
        const href = trigger.getAttribute("data-project-href") || "";
        title.textContent =
          trigger.getAttribute("data-project-name") || "Project detail";
        copy.textContent = trigger.getAttribute("data-project-summary") || "";
        actions.hidden = !href;
        link.href = href || "#";
        setScrollLock(true);
        dialog.showModal();
      });
    });

    dialog.addEventListener("close", () => {
      setScrollLock(false);
    });

    dialog.addEventListener("cancel", () => {
      setScrollLock(false);
    });

    dialog.addEventListener("click", (event) => {
      const bounds = dialog.getBoundingClientRect();
      const clickedOutside =
        event.clientX < bounds.left ||
        event.clientX > bounds.right ||
        event.clientY < bounds.top ||
        event.clientY > bounds.bottom;

      if (clickedOutside) {
        dialog.close();
      }
    });
  }
</script>

<style>
  .project-dialog {
    width: min(42rem, calc(100% - 1.5rem));
    margin: auto;
    padding: 0;
    color: var(--color-text);
    background: rgb(6 10 16 / 98%);
    border: 1px solid rgb(255 255 255 / 12%);
    will-change: transform, opacity;
    opacity: 0;
    transform: translateY(20px) scale(0.986);
    transform-origin: center center;
    pointer-events: none;
  }

  .project-dialog::backdrop {
    background: rgb(0 0 0 / 0%);
    backdrop-filter: blur(0);
    transition:
      background 260ms cubic-bezier(0.2, 0.9, 0.2, 1),
      backdrop-filter 260ms cubic-bezier(0.2, 0.9, 0.2, 1);
  }

  .dialog-shell {
    padding: 1.5rem;
  }

  .dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .dialog-header .eyebrow {
    margin: 0;
  }

  .dialog-close {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 999px;
    color: var(--color-text);
    background: rgb(255 255 255 / 4%);
  }

  .dialog-title {
    margin: 0.4rem 0 1rem;
    font-family: Cabin, "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .dialog-copy {
    margin: 0;
    white-space: pre-line;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .dialog-actions {
    margin-top: 1.25rem;
  }

  .project-dialog[open] {
    pointer-events: auto;
    animation: dialog-in 260ms cubic-bezier(0.16, 0.84, 0.52, 1) both;
  }

  @keyframes dialog-in {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.986);
      filter: blur(1px);
    }

    60% {
      opacity: 1;
      transform: translateY(-6px) scale(1.02);
      filter: blur(0);
    }

    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  .project-dialog[open]::backdrop {
    background: rgb(0 0 0 / 75%);
    backdrop-filter: blur(12px);
  }

  .dialog-header,
  .dialog-title,
  .dialog-copy,
  .dialog-actions {
    opacity: 0;
    transform: translateY(6px);
    will-change: transform, opacity;
  }

  .project-dialog[open] .dialog-header {
    animation: content-fade 260ms ease both;
    animation-delay: 90ms;
  }

  .project-dialog[open] .dialog-title {
    animation: content-fade 260ms ease both;
    animation-delay: 140ms;
  }

  .project-dialog[open] .dialog-copy {
    animation: content-fade 320ms ease both;
    animation-delay: 180ms;
  }

  .project-dialog[open] .dialog-actions {
    animation: content-fade 320ms ease both;
    animation-delay: 220ms;
  }

  @keyframes content-fade {
    from {
      opacity: 0;
      transform: translateY(6px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-dialog,
    .project-dialog::backdrop,
    .project-dialog[open],
    .dialog-header,
    .dialog-title,
    .dialog-copy,
    .dialog-actions {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
      filter: none !important;
    }
  }
</style>
