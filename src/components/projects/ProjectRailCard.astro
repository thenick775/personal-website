---
import { Image } from "astro:assets";
import type { Project } from "../../data/projects";

interface Props {
  project: Project;
  image: string;
  imageWidth: number;
  imageHeight: number;
  summary: string;
  meta: string;
}

const { project, image, imageWidth, imageHeight, summary, meta } = Astro.props;
---

<article class="project-rail-card surface-panel">
  <div class="project-rail-media">
    <Image
      src={image}
      alt={`${project.name} preview`}
      width={imageWidth}
      height={imageHeight}
      loading="lazy"
      decoding="async"
    />
    <div class="project-rail-overlay"></div>
  </div>

  <div class="project-rail-content">
    <p class="project-rail-meta">{meta}</p>
    <h3>{project.name}</h3>
    <p>{summary}</p>

    <ul class="project-rail-tags" aria-label={`${project.name} technologies`}>
      {project.labels.map((label) => <li>{label}</li>)}
    </ul>

    <button
      class="button-pill button-primary"
      type="button"
      data-project-detail
      data-project-href={project.href ?? ""}
      data-project-name={project.name}
      data-project-summary={project.summary}
    >
      More detail
    </button>
  </div>
</article>

<style>
  .project-rail-card {
    display: grid;
    grid-template-rows: minmax(13rem, 18rem) auto;
    align-self: start;
    height: 100%;
    overflow: hidden;
    scroll-snap-align: start;
    will-change: transform;
    transform: translateZ(0);
    backface-visibility: hidden;
    background: rgb(8 12 18 / 92%);
    box-shadow: 0 14px 32px rgb(0 0 0 / 24%);
  }

  .project-rail-media {
    min-height: 13rem;
    position: relative;
    overflow: hidden;
    background: rgb(255 255 255 / 3%);
    transform: translateZ(0);
  }

  .project-rail-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-rail-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgb(2 3 5 / 4%), rgb(2 3 5 / 52%));
  }

  .project-rail-content {
    display: grid;
    gap: 0.85rem;
    padding: 0.5rem 1rem 1rem;
  }

  .project-rail-meta {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .project-rail-content h3 {
    margin: 0;
    font-family: Cabin, "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: clamp(1.45rem, 2.8vw, 2.4rem);
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project-rail-content p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .project-rail-content > p {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .project-rail-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
  }

  .project-rail-tags li {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.68rem;
    border: 1px solid rgb(255 255 255 / 10%);
    border-radius: 999px;
    background: rgb(255 255 255 / 5%);
    color: rgb(245 247 251 / 92%);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    line-height: 1.2;
    white-space: nowrap;
  }

  .project-rail-tags li:nth-child(n + 4) {
    display: none;
  }

  @media (--tablet-and-up) {
    .project-rail-card {
      background:
        radial-gradient(
          circle at top right,
          rgb(66 220 163 / 16%),
          transparent 28%
        ),
        rgb(8 12 18 / 92%);
      box-shadow: var(--shadow-elevated);
    }

    .project-rail-media {
      min-height: 18rem;
    }

    .project-rail-content {
      gap: 1rem;
      padding: 0.5rem 1.1rem 1.1rem;
    }

    .project-rail-content > p {
      -webkit-line-clamp: 4;
    }

    .project-rail-tags {
      gap: 0.5rem;
    }

    .project-rail-tags li:nth-child(n + 4) {
      display: inline-flex;
    }
  }
</style>
