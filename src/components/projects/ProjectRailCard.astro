---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
  image: string;
  summary: string;
  meta: string;
}

const { project, image, summary, meta } = Astro.props;
---

<article class="project-rail-card surface-panel">
  <div class="project-rail-media">
    <img
      src={image}
      alt={`${project.name} preview image`}
      loading="lazy"
      decoding="async"
    />
    <div class="project-rail-overlay"></div>
  </div>

  <div class="project-rail-content">
    <p class="project-rail-meta">{meta}</p>
    <h3>{project.name}</h3>
    <p>{summary}</p>

    <ul class="project-rail-tags" aria-label={`${project.name} technologies`}>
      {project.labels.map((label) => <li>{label}</li>)}
    </ul>

    <button
      class="button-pill button-primary"
      type="button"
      data-project-detail
      data-project-href={project.href ?? ''}
      data-project-name={project.name}
      data-project-summary={project.summary}
    >
      More detail
    </button>
  </div>
</article>

<style>
  .project-rail-card {
    display: grid;
    grid-template-rows: minmax(13rem, 18rem) auto;
    align-self: start;
    height: 100%;
    overflow: hidden;
    scroll-snap-align: start;
    will-change: transform;
    transform: translateZ(0);
    backface-visibility: hidden;
    background: rgba(8, 12, 18, 0.92);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.24);
  }

  .project-rail-media {
    min-height: 13rem;
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    transform: translateZ(0);
  }

  .project-rail-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-rail-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(2, 3, 5, 0.04),
      rgba(2, 3, 5, 0.52)
    );
  }

  .project-rail-content {
    display: grid;
    gap: 0.85rem;
    padding: 0.5rem 1rem 1rem;
  }

  .project-rail-meta {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .project-rail-content h3 {
    margin: 0;
    font-family: 'Cabin', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(1.45rem, 2.8vw, 2.4rem);
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project-rail-content p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .project-rail-content > p {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .project-rail-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
  }

  .project-rail-tags li {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.68rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(245, 247, 251, 0.92);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    line-height: 1.2;
    white-space: nowrap;
  }

  .project-rail-tags li:nth-child(n + 4) {
    display: none;
  }

  @media (--tablet-and-up) {
    .project-rail-card {
      background:
        radial-gradient(
          circle at top right,
          rgba(66, 220, 163, 0.16),
          transparent 28%
        ),
        rgba(8, 12, 18, 0.92);
      box-shadow: var(--shadow-elevated);
    }

    .project-rail-media {
      min-height: 18rem;
    }

    .project-rail-content {
      gap: 1rem;
      padding: 0.5rem 1.1rem 1.1rem;
    }

    .project-rail-content > p {
      -webkit-line-clamp: 4;
    }

    .project-rail-tags {
      gap: 0.5rem;
    }

    .project-rail-tags li:nth-child(n + 4) {
      display: inline-flex;
    }
  }
</style>
