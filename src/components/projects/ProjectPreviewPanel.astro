---
import { Image } from "astro:assets";
import type { Project } from "../../data/projects";

interface Props {
  project: Project;
  panelId: string;
  image: string;
  imageWidth: number;
  imageHeight: number;
  summary: string;
  detail: string;
  meta: string;
  active: boolean;
}

const {
  project,
  panelId,
  image,
  imageWidth,
  imageHeight,
  summary,
  detail,
  meta,
  active,
} = Astro.props;
---

<article
  id={panelId}
  class:list={[
    "project-preview-panel",
    active && "is-active",
    !active && "is-hidden",
  ]}
  aria-hidden={active ? "false" : "true"}
  data-project-preview-panel
>
  <div class="project-preview-media">
    <Image
      src={image}
      alt={`${project.name} preview`}
      width={imageWidth}
      height={imageHeight}
      loading="lazy"
      decoding="async"
    />
    <div class="project-preview-overlay"></div>
    <div class="project-preview-badge">{meta}</div>
  </div>

  <div class="project-preview-content">
    <div class="project-preview-head">
      <h3 class="project-preview-title">{project.name}</h3>
      <div class="project-preview-summary-wrap">
        <p class="project-preview-summary">{summary}</p>
      </div>
    </div>

    <div class="project-preview-footer">
      <ul
        class="project-preview-tags"
        aria-label={`${project.name} technologies`}
      >
        {project.labels.map((label) => <li>{label}</li>)}
      </ul>

      <div class="project-preview-actions">
        <button
          class="button-pill button-primary project-preview-detail-trigger"
          type="button"
          data-project-inline-detail-trigger
          data-project-inline-detail-target={`${panelId}-detail`}
        >
          More detail
        </button>

        <div class="project-preview-detail-actions">
          {
            project.href && (
              <a
                class="button-pill button-primary"
                href={project.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                View project
              </a>
            )
          }

          <button
            class="button-pill"
            type="button"
            data-project-inline-detail-close
            data-project-inline-detail-target={`${panelId}-detail`}
          >
            Close detail
          </button>
        </div>
      </div>
    </div>

    <div
      id={`${panelId}-detail`}
      class="project-preview-detail is-collapsed"
      data-project-inline-detail
      aria-hidden="true"
    >
      <div
        class="project-preview-detail-shell"
        data-project-inline-detail-shell
      >
        <p class="project-preview-detail-copy">{detail}</p>
      </div>
    </div>
  </div>
</article>

<script>
  const previewPanels = Array.from(
    document.querySelectorAll("[data-project-preview-panel]"),
  );

  previewPanels.forEach((panel) => {
    if (!(panel instanceof HTMLElement)) return;

    const detail = panel.querySelector("[data-project-inline-detail]");
    const detailShell = panel.querySelector(
      "[data-project-inline-detail-shell]",
    );
    const detailTrigger = panel.querySelector(
      "[data-project-inline-detail-trigger]",
    );
    const detailClose = panel.querySelector(
      "[data-project-inline-detail-close]",
    );

    if (
      !(detail instanceof HTMLElement) ||
      !(detailShell instanceof HTMLElement) ||
      !(detailTrigger instanceof HTMLButtonElement) ||
      !(detailClose instanceof HTMLButtonElement)
    ) {
      return;
    }

    const setExpanded = (expanded: boolean) => {
      detail.style.setProperty(
        "--project-detail-height",
        `${detailShell.scrollHeight + 2}px`,
      );
      detail.classList.toggle("is-collapsed", !expanded);
      detail.setAttribute("aria-hidden", expanded ? "false" : "true");
      panel.classList.toggle("is-detail-open", expanded);
      detailTrigger.setAttribute("aria-expanded", expanded ? "true" : "false");
    };

    detailTrigger.addEventListener("click", () => setExpanded(true));
    detailClose.addEventListener("click", () => setExpanded(false));

    const collapseIfInactive = () => {
      const hidden =
        panel.classList.contains("is-hidden") ||
        panel.getAttribute("aria-hidden") === "true";

      if (hidden) {
        setExpanded(false);
      }
    };

    const observer = new MutationObserver(collapseIfInactive);
    observer.observe(panel, {
      attributes: true,
      attributeFilter: ["class", "aria-hidden"],
    });

    setExpanded(false);
  });
</script>

<style>
  .project-preview-panel {
    display: grid;
    min-height: 0;
  }

  .project-preview-panel.is-hidden {
    display: none;
  }

  .project-preview-media {
    position: relative;
    overflow: hidden;
    background: rgb(255 255 255 / 3%);
  }

  .project-preview-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-preview-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgb(2 3 5 / 5%), rgb(2 3 5 / 68%)),
      linear-gradient(120deg, rgb(2 3 5 / 20%), transparent 45%);
  }

  .project-preview-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    padding: 0.42rem 0.7rem;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 999px;
    background: rgb(2 3 5 / 55%);
    backdrop-filter: blur(8px);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-preview-content {
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    align-content: start;
  }

  .project-preview-head {
    display: grid;
    gap: 0.8rem;
    min-height: 0;
  }

  .project-preview-title {
    margin: 0;
    font-family: Cabin, "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: clamp(1.45rem, 2.8vw, 1.75rem);
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project-preview-summary-wrap {
    display: grid;
    grid-template-rows: 1fr;
    min-height: 0;
    transition:
      grid-template-rows 420ms cubic-bezier(0.2, 0.82, 0.24, 1),
      opacity 220ms ease,
      transform 420ms cubic-bezier(0.2, 0.82, 0.24, 1);
  }

  .project-preview-summary {
    margin: 0;
    min-height: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .project-preview-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }

  .project-preview-tags li {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.68rem;
    border: 1px solid rgb(255 255 255 / 10%);
    border-radius: 999px;
    background: rgb(255 255 255 / 5%);
    color: rgb(245 247 251 / 92%);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    line-height: 1.2;
    white-space: nowrap;
  }

  .project-preview-footer {
    display: grid;
    gap: 0.85rem;
  }

  .project-preview-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    position: relative;
    min-height: 2.75rem;
  }

  .project-preview-detail-trigger {
    position: relative;
    z-index: 1;
    transition:
      opacity 180ms ease,
      transform 240ms cubic-bezier(0.2, 0.82, 0.24, 1);
  }

  .project-preview-detail {
    display: grid;
    gap: 0;
    max-height: var(--project-detail-height, 0);
    border-top: 1px solid rgb(255 255 255 / 8%);
    overflow: hidden;
    opacity: 1;
    transition:
      max-height 420ms cubic-bezier(0.2, 0.82, 0.24, 1),
      opacity 220ms ease,
      border-color 220ms ease;
  }

  .project-preview-detail.is-collapsed {
    max-height: 0;
    opacity: 0;
    border-top-color: transparent;
    pointer-events: none;
  }

  .project-preview-detail-copy {
    margin: 0;
    white-space: pre-line;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .project-preview-detail-shell {
    display: grid;
    gap: 1rem;
    padding-top: 1rem;
    opacity: 1;
    transform: translateY(0);
    clip-path: inset(0 0 0 0);
    transition:
      opacity 260ms ease,
      transform 420ms cubic-bezier(0.2, 0.82, 0.24, 1),
      clip-path 420ms cubic-bezier(0.2, 0.82, 0.24, 1);
  }

  .project-preview-detail.is-collapsed .project-preview-detail-shell {
    opacity: 0;
    transform: translateY(0.85rem);
    clip-path: inset(0 0 100% 0);
  }

  .project-preview-detail-actions {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem;
    position: absolute;
    top: 50%;
    right: 0;
    justify-content: flex-end;
    opacity: 0;
    transform: translateY(calc(-50% + 0.35rem));
    pointer-events: none;
    transition:
      opacity 180ms ease,
      transform 240ms cubic-bezier(0.2, 0.82, 0.24, 1);
  }

  .project-preview-detail-actions > * {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  @media (--split-content-and-up) {
    .project-preview-panel {
      grid-template-rows: minmax(10rem, 1fr) auto;
      height: 100%;
      min-height: 0;
    }

    .project-preview-media {
      min-height: 10rem;
    }

    .project-preview-content {
      gap: 0.75rem;
      padding: 0.95rem 1.05rem 1.05rem;
      min-height: 0;
    }

    .project-preview-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem 1rem;
      flex-wrap: wrap;
    }

    .project-preview-tags {
      flex: 1 1 18rem;
    }

    .project-preview-actions {
      flex: 0 0 auto;
      margin-left: auto;
    }

    .project-preview-detail-shell {
      gap: 1.1rem;
      padding-top: 1.15rem;
    }

    .project-preview-panel.is-detail-open .project-preview-summary-wrap {
      grid-template-rows: 0fr;
      opacity: 0;
      transform: translateY(-0.45rem);
      overflow: hidden;
    }

    .project-preview-panel.is-detail-open .project-preview-detail-trigger {
      opacity: 0;
      transform: translateY(-0.25rem);
      pointer-events: none;
    }

    .project-preview-panel.is-detail-open .project-preview-detail-actions {
      opacity: 1;
      transform: translateY(-50%);
      pointer-events: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-preview-detail,
    .project-preview-detail-shell,
    .project-preview-summary-wrap,
    .project-preview-detail-trigger,
    .project-preview-detail-actions {
      transition: none;
    }
  }
</style>
