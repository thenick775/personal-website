---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
  panelId: string;
  image: string;
  summary: string;
  meta: string;
  active: boolean;
}

const { project, panelId, image, summary, meta, active } = Astro.props;
---

<article
  id={panelId}
  class:list={[
    'project-preview-panel',
    active && 'is-active',
    !active && 'is-hidden',
  ]}
  aria-hidden={active ? 'false' : 'true'}
  data-project-preview-panel
>
  <div class="project-preview-media">
    <img
      src={image}
      alt={`${project.name} preview image`}
      loading={active ? 'eager' : 'lazy'}
      decoding="async"
    />
    <div class="project-preview-overlay"></div>
    <div class="project-preview-badge">{meta}</div>
  </div>

  <div class="project-preview-content">
    <div>
      <h3 class="project-preview-title">{project.name}</h3>
      <p class="project-preview-summary">{summary}</p>
    </div>

    <div class="project-preview-footer">
      <ul
        class="project-preview-tags"
        aria-label={`${project.name} technologies`}
      >
        {project.labels.map((label) => <li>{label}</li>)}
      </ul>

      <div class="project-preview-actions">
        {
          project.personal && project.href ? (
            <a
              class="button-pill button-primary"
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              View project
            </a>
          ) : (
            <button
              class="button-pill button-primary"
              type="button"
              data-project-detail
              data-project-name={project.name}
              data-project-description={project.detail ?? ''}
            >
              Project detail
            </button>
          )
        }
      </div>
    </div>
  </div>
</article>

<style>
  .project-preview-panel {
    display: grid;
    min-height: 0;
  }

  .project-preview-panel.is-hidden {
    display: none;
  }

  .project-preview-media {
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
  }

  .project-preview-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-preview-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(2, 3, 5, 0.05), rgba(2, 3, 5, 0.68)),
      linear-gradient(120deg, rgba(2, 3, 5, 0.2), transparent 45%);
  }

  .project-preview-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    padding: 0.42rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(2, 3, 5, 0.55);
    backdrop-filter: blur(8px);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-preview-content {
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    align-content: start;
  }

  .project-preview-title {
    margin: 0;
    font-family: 'Cabin', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(1.45rem, 2.8vw, 2.4rem);
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project-preview-summary {
    margin: 0.8rem 0 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .project-preview-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }

  .project-preview-tags li {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.68rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(245, 247, 251, 0.92);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    line-height: 1.2;
    white-space: nowrap;
  }

  .project-preview-footer {
    display: grid;
    gap: 0.85rem;
  }

  .project-preview-actions {
    display: flex;
    justify-content: flex-start;
  }

  @media (--split-content-and-up) {
    .project-preview-panel {
      grid-template-rows: minmax(10rem, 1fr) auto;
      height: 100%;
      min-height: 0;
    }

    .project-preview-media {
      min-height: 10rem;
    }

    .project-preview-content {
      gap: 0.75rem;
      padding: 0.95rem 1.05rem 1.05rem;
      min-height: 0;
    }

    .project-preview-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem 1rem;
      flex-wrap: wrap;
    }

    .project-preview-tags {
      flex: 1 1 18rem;
    }

    .project-preview-actions {
      flex: 0 0 auto;
      margin-left: auto;
    }
  }
</style>
