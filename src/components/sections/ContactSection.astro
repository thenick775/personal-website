---

<section id="contact" class="section-block viewport-section contact-section">
  <div class="section-shell contact-grid" data-scroll-anchor>
    <div>
      <p class="eyebrow">Contact</p>
      <h2 class="section-heading">{title}</h2>
      <p class="section-copy">{intro}</p>
    </div>

    <ul class="contact-links">
      {
        links.map((link) => (
          <li>
            <a
              class="button-pill contact-pill"
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
            >
              <span class="contact-icon" set:html={contactIcons[link.icon]} />
              <span class="contact-label">{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .contact-section {
    min-height: 100svh;
    display: flex;
    align-items: center;
  }

  .contact-grid {
    display: grid;
    gap: 1.5rem;
  }

  .contact-links {
    list-style: none;
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
  }

  .contact-pill {
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    justify-content: center;
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4em;
    height: 1.1em;
    color: currentColor;
    flex-shrink: 0;
  }

  .contact-label {
    display: inline-block;
    line-height: 1;
  }

  .contact-icon :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
    fill: currentColor;
    transform: scaleY(-1);
    transform-origin: center;
  }

  @media (--tablet-and-up) {
    .contact-pill {
      min-height: 3rem;
      gap: 0.65rem;
    }
  }

  @media (--split-content-and-up) {
    .contact-grid {
      grid-template-columns: minmax(14rem, 24rem) minmax(0, 1fr);
      align-items: center;
    }

    .contact-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
