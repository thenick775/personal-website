---
import type { Project } from "../../data/projects";
import "swiper/css";
import "swiper/css/effect-cards";
import ProjectDetailDialog from "../projects/ProjectDetailDialog.astro";
import ProjectListItem from "../projects/ProjectListItem.astro";
import ProjectPreviewPanel from "../projects/ProjectPreviewPanel.astro";
import ProjectRailCard from "../projects/ProjectRailCard.astro";
import ScrollArea from "../projects/ScrollArea.astro";
import SectionNextLink from "../site/SectionNextLink.astro";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const getMeta = (project: Project) =>
  project.personal ? "Personal project" : "Professional work";

const getShortMeta = (project: Project) =>
  project.personal ? "Personal" : "Professional";

const getProjectPanelId = (index: number) => `project-preview-panel-${index}`;

const initialProject = projects[0];
---

<section id="projects" class="section-block viewport-section projects-section">
  <div class="section-shell" data-scroll-anchor>
    <div class="projects-heading-row">
      <div>
        <p class="eyebrow">Projects</p>
        <h2 class="section-heading">Selected projects.</h2>
        <p class="section-copy projects-copy">
          A mix of projects I've built for work, fun, and for the sake of
          figuring things out.
        </p>
      </div>
    </div>

    {
      initialProject && (
        <>
          <div class="projects-spotlight surface-panel">
            <div class="projects-list-wrap" data-projects-list-wrap>
              <div class="projects-list-header">
                <p class="projects-list-label">Project index</p>
                <div class="projects-list-nav" aria-label="Project navigation">
                  <button
                    class="projects-list-nav-button"
                    type="button"
                    aria-label="Previous project"
                    data-project-nav="prev"
                  >
                    <svg viewBox="0 0 12 12" aria-hidden="true">
                      <path d="M6 2 10 8H2Z" fill="currentColor" />
                    </svg>
                  </button>
                  <button
                    class="projects-list-nav-button"
                    type="button"
                    aria-label="Next project"
                    data-project-nav="next"
                  >
                    <svg viewBox="0 0 12 12" aria-hidden="true">
                      <path d="M2 4h8L6 10Z" fill="currentColor" />
                    </svg>
                  </button>
                </div>
              </div>
              <ScrollArea
                class="projects-list-shell"
                viewportClass="projects-list"
                label="Projects"
              >
                <div role="tablist" aria-label="Projects" data-projects-list>
                  {projects.map((project, index) => (
                    <ProjectListItem
                      projectName={project.name}
                      projectMeta={getMeta(project)}
                      panelId={getProjectPanelId(index)}
                      index={index}
                      active={index === 0}
                    />
                  ))}
                </div>
              </ScrollArea>
            </div>

            <div class="project-preview-stack" aria-live="polite">
              {projects.map((project, index) => {
                return (
                  <ProjectPreviewPanel
                    project={project}
                    panelId={getProjectPanelId(index)}
                    image={project.previewImage}
                    imageWidth={1440}
                    imageHeight={900}
                    meta={getShortMeta(project)}
                    summary={project.shortSummary}
                    detail={project.summary}
                    active={index === 0}
                  />
                );
              })}
            </div>
          </div>

          <div
            class="project-rail swiper"
            aria-label="Project gallery"
            data-project-rail
          >
            <div class="swiper-wrapper">
              {projects.map((project) => {
                return (
                  <div class="swiper-slide">
                    <ProjectRailCard
                      project={project}
                      image={project.railImage}
                      imageWidth={720}
                      imageHeight={900}
                      meta={getMeta(project)}
                      summary={project.shortSummary}
                    />
                  </div>
                );
              })}
            </div>
          </div>
        </>
      )
    }

    <div class="section-next-wrap">
      <SectionNextLink href="#contact" label="Scroll to contact section" />
    </div>
  </div>
  <ProjectDetailDialog />
</section>

<script>
  import Swiper from "swiper";
  import { EffectCards } from "swiper/modules";

  const rail = document.querySelector("[data-project-rail]");
  if (rail instanceof HTMLElement) {
    new Swiper(rail, {
      modules: [EffectCards],
      effect: "cards",
      grabCursor: true,
      autoHeight: true,
      slidesPerView: 1,
      cardsEffect: {
        perSlideOffset: 7,
        perSlideRotate: 1,
        rotate: true,
        slideShadows: false,
      },
      longSwipesMs: 180,
      longSwipesRatio: 0.2,
      speed: 400,
      observer: true,
      observeParents: true,
    });
  }

  const previewRoot = document.querySelector(".projects-spotlight");
  if (previewRoot instanceof HTMLElement) {
    const triggers = Array.from(
      previewRoot.querySelectorAll("[data-project-preview-trigger]"),
    );
    const panels = Array.from(
      previewRoot.querySelectorAll("[data-project-preview-panel]"),
    );
    const prevButton = previewRoot.querySelector('[data-project-nav="prev"]');
    const nextButton = previewRoot.querySelector('[data-project-nav="next"]');

    const syncPreview = (trigger: HTMLElement) => {
      if (!(trigger instanceof HTMLButtonElement)) return;

      const targetId = trigger.dataset.projectPreviewTarget;
      if (!targetId) return;

      triggers.forEach((item) => {
        if (!(item instanceof HTMLButtonElement)) return;

        const active = item === trigger;
        item.classList.toggle("is-active", active);
        item.setAttribute("aria-selected", active ? "true" : "false");
        item.setAttribute("tabindex", active ? "0" : "-1");
      });

      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;

        const active = panel.id === targetId;
        panel.classList.toggle("is-active", active);
        panel.classList.toggle("is-hidden", !active);
        panel.setAttribute("aria-hidden", active ? "false" : "true");
      });
    };

    const getActiveIndex = () =>
      triggers.findIndex(
        (item) =>
          item instanceof HTMLButtonElement &&
          item.classList.contains("is-active"),
      );

    const selectByOffset = (offset: number) => {
      const activeIndex = getActiveIndex();
      if (activeIndex < 0 || triggers.length === 0) return;

      const nextIndex =
        (activeIndex + offset + triggers.length) % triggers.length;
      const nextTrigger = triggers[nextIndex];

      if (!(nextTrigger instanceof HTMLButtonElement)) return;

      syncPreview(nextTrigger);
      nextTrigger.focus();
      nextTrigger.scrollIntoView({ block: "nearest", behavior: "smooth" });
    };

    triggers.forEach((trigger) => {
      if (!(trigger instanceof HTMLButtonElement)) return;
      trigger.addEventListener("focus", () => syncPreview(trigger));
      trigger.addEventListener("click", () => syncPreview(trigger));
    });

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener("click", () => selectByOffset(-1));
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener("click", () => selectByOffset(1));
    }
  }
</script>

<style>
  .projects-section {
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .projects-heading-row {
    display: grid;
    gap: 1rem;
  }

  .projects-copy {
    max-width: 32rem;
  }

  .projects-spotlight {
    display: none;
    overflow: hidden;
    background:
      radial-gradient(
        circle at top right,
        rgb(66 220 163 / 14%),
        transparent 34%
      ),
      rgb(8 12 18 / 92%);
  }

  .projects-list-wrap {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    border-bottom: 1px solid rgb(255 255 255 / 8%);
  }

  .projects-list-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-right: 1rem;
  }

  .projects-list-label {
    margin: 0;
    padding: 1rem 0 1rem 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .projects-list-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .projects-list-nav-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid rgb(255 255 255 / 12%);
    border-radius: 999px;
    background: rgb(255 255 255 / 4%);
    color: var(--color-text-muted);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .projects-list-nav-button svg {
    width: 0.7rem;
    height: 0.7rem;
    display: block;
  }

  .projects-list-nav-button:hover,
  .projects-list-nav-button:focus-visible {
    border-color: rgb(66 220 163 / 40%);
    background: rgb(66 220 163 / 8%);
    color: var(--color-text);
    transform: translateY(-1px);
    outline: none;
  }

  :global(.projects-list) {
    padding: 1rem;
    min-height: 0;
  }

  [data-projects-list] {
    display: grid;
    gap: 0.5rem;
  }

  .project-preview-stack {
    height: 100%;
    min-height: 0;
  }

  .section-next-wrap {
    display: flex;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .project-rail {
    width: min(calc(100% - 2rem), 22rem);
    margin: 0 auto;
    padding: 1rem 0 0.75rem;
  }

  .project-rail :global(.swiper-wrapper) {
    align-items: stretch;
  }

  .project-rail :global(.swiper-slide) {
    box-sizing: border-box;
    display: flex;
    height: 100%;
    padding: 0 0.25rem 0.75rem;
  }

  .project-rail :global(.swiper-slide) > * {
    width: 100%;
    height: 100%;
  }

  @media (--tablet-and-up) {
    .projects-heading-row {
      grid-template-columns: minmax(0, 1fr);
    }

    .projects-copy {
      max-width: 100%;
    }
  }

  @media (--split-content-and-up) {
    .projects-spotlight {
      display: grid;
      grid-template-columns: minmax(19rem, 22rem) minmax(0, 1fr);
      height: min(43rem, calc(100lvh - var(--nav-offset) - 11rem));
      min-height: 33rem;
    }

    .projects-spotlight > * {
      min-height: 0;
    }

    .projects-list-wrap {
      border-right: 1px solid rgb(255 255 255 / 8%);
      border-bottom: 0;
      height: 100%;
      min-height: 0;
    }

    :global(.projects-list) {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }

    .project-rail {
      display: none;
    }
  }
</style>
