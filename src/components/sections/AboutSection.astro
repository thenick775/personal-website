---
import SectionNextLink from "../site/SectionNextLink.astro";

interface Props {
  title: string;
  paragraphs: string[];
}

const { title, paragraphs } = Astro.props;
---

<section id="about" class="section-block viewport-section about-section">
  <div class="section-shell about-grid" data-scroll-anchor>
    <div>
      <p class="eyebrow">About</p>
      <h2 class="section-heading">{title}</h2>
    </div>
    <div class="surface-panel about-copy">
      {paragraphs.map((paragraph) => <p class="section-copy">{paragraph}</p>)}
    </div>
    <div class="section-next-wrap">
      <SectionNextLink href="#skills" label="Scroll to skills section" />
    </div>
  </div>
</section>

<style>
  .about-section {
    display: flex;
    align-items: center;
    background: url("/images/IMG_1615_min.jpg") center center / cover no-repeat
      scroll black;
  }

  .about-grid {
    display: grid;
    gap: 1.5rem;
  }

  .section-next-wrap {
    display: flex;
    justify-content: center;
  }

  .about-grid > div:first-child {
    align-self: start;
  }

  .about-copy {
    padding: clamp(1.4rem, 3vw, 2rem);
    background: rgb(0 0 0 / 74%);
    text-shadow: 0 0 10px rgb(0 0 0 / 95%);
  }

  .about-copy p + p {
    margin-top: 1rem;
  }

  @media (--tablet-and-up) {
    .about-section {
      padding-top: var(--section-padding);
      padding-bottom: var(--section-padding);
    }
  }

  @media (--split-content-and-up) {
    .about-grid {
      grid-template-columns: minmax(14rem, 18rem) minmax(0, 1fr);
      align-items: start;
    }

    .section-next-wrap {
      grid-column: 2 / -1;
    }
  }
</style>
