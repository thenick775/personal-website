---
import SectionNextLink from '../site/SectionNextLink.astro';
import type { Skill } from '../../data/skills';

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<section id="skills" class="section-block viewport-section skills-section">
  <div class="section-shell skills-shell" data-scroll-anchor>
    <div class="skills-copy">
      <p class="eyebrow">Skills</p>
      <h2 class="section-heading">Tools and technologies.</h2>
      <p class="section-copy section-intro">Click for more information.</p>
    </div>

    <div class="skills-gallery surface-panel">
      <ul class="skills-grid" aria-label="Skills list">
        {
          skills.map((skill) => (
            <li>
              <a
                class="skill-pill"
                href={skill.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={skill.label}
                title={skill.label}
              >
                <img
                  class="skill-icon"
                  src={skill.icon}
                  alt=""
                  loading="lazy"
                  width="72"
                  height="72"
                />
                <span class="visually-hidden">{skill.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="section-next-wrap">
      <SectionNextLink href="#projects" label="Scroll to projects section" />
    </div>
  </div>
</section>

<style>
  .skills-section {
    min-height: 100svh;
    display: flex;
    align-items: center;
  }

  .skills-shell {
    display: grid;
    gap: 1.5rem;
  }

  .section-next-wrap {
    display: flex;
    justify-content: center;
  }

  .skills-copy {
    max-width: 32rem;
  }

  .section-intro {
    margin-bottom: 0;
  }

  .skills-gallery {
    padding: clamp(1.1rem, 2.5vw, 1.75rem);
    background: rgb(8 12 18 / 88%);
  }

  .skills-grid {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.7rem 0.8rem;
    margin: 0;
    padding: 0;
  }

  .skill-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.6rem;
    height: 4.6rem;
    padding: 0.4rem;
    border-radius: 1rem;
    background: rgb(255 255 255 / 2.5%);
    border: 1px solid rgb(255 255 255 / 8%);
    transition:
      transform 160ms ease,
      filter 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .skill-pill:hover,
  .skill-pill:focus-visible {
    transform: translateY(-4px);
    filter: brightness(1.06);
    border-color: rgb(66 220 163 / 40%);
    background: rgb(66 220 163 / 6%);
    outline: none;
  }

  .skill-icon {
    display: block;
    width: 3.85rem;
    height: 3.85rem;
    object-fit: contain;
  }

  @media (--tablet-and-up) {
    .skills-shell {
      gap: 2rem;
    }

    .skills-copy {
      max-width: 100%;
    }

    .skills-gallery {
      padding: 1.75rem 2rem;
    }

    .skills-grid {
      gap: 1rem 1.4rem;
    }

    .skill-pill {
      width: 5.75rem;
      height: 5.75rem;
    }

    .skill-icon {
      width: 4.75rem;
      height: 4.75rem;
    }

    .section-next-wrap {
      grid-column: 1 / -1;
    }
  }
</style>
